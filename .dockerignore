# .dockerignore - Exclude files from Docker build context

# Claude Code parallel-dev git worktrees — each holds a full source checkout.
# node_modules/dist below are filtered, but the source itself would otherwise
# ship ~100MB / thousands of files to BuildKit on every local rebuild. Not
# needed by any build stage. NB: only worktrees/ is excluded — the rest of
# .claude/ (skills, commands) is baked into the agent-sidecar image via
# `COPY .claude/` in agent-sidecar/Dockerfile, so it MUST stay in context.
.claude/worktrees

# Local dev/prod environment descriptors — these contain live URLs, API keys,
# and admin credentials (see CLAUDE.md). No build stage copies them, but they
# must never enter the build context.
environment-details.xml
environment-config.xml

# Standalone proof-of-concept apps not part of the main image build
auth-proxy-poc

# Dependencies (will be installed during build)
node_modules
*/node_modules
**/node_modules

# Build outputs (will be generated during build)
dist
*/dist
**/dist
client/dist
server/dist
lib/dist

# Build artifacts
server/public

# Development files
*.log
server/logs
*.local
.env
.env.local
.env.*.local
.env.development
.env.test

# Git
.git
.gitignore
.gitattributes

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing
coverage
*/coverage
**/coverage
*.test.ts
*.test.js
**/__tests__
**/*.test.ts
**/*.test.js
jest.config.js
*/jest.config.js

# Documentation
*.md
!README.md
projectmanagement
docs

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Temporary files
*.tmp
*.temp
.cache
.parcel-cache

# Database files (will be in mounted volume)
*.db
*.db-journal
*.db-shm
*.db-wal
server/prisma/dev.db*

# SQLite tools
sqlite3.exe
sqlite3_analyzer.exe
sqldiff.exe

# Docker files
docker-compose.yml
docker-compose.yaml
docker-compose.*.yml
Dockerfile
.dockerignore

# Misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
