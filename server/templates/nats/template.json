{
  "name": "nats",
  "displayName": "NATS",
  "builtinVersion": 1,
  "scope": "host",
  "category": "infrastructure",
  "description": "NATS messaging server with JetStream persistence. Reads its config from Vault KV, so the Vault stack must be bootstrapped first.",
  "parameters": [
    {
      "name": "nats-host-port",
      "type": "number",
      "default": 4222,
      "description": "Bind the NATS client port on the host."
    },
    {
      "name": "nats-monitor-port",
      "type": "number",
      "default": 8222,
      "description": "Bind the NATS HTTP monitoring port on the host."
    }
  ],
  "resourceOutputs": [
    { "type": "docker-network", "purpose": "nats", "joinSelf": true }
  ],
  "networks": [],
  "volumes": [
    { "name": "nats_data" }
  ],
  "requires": [
    { "kind": "stack", "templateName": "vault", "minState": "synced", "scopeMatch": "host" },
    { "kind": "predicate", "name": "vault-bootstrapped" }
  ],
  "services": [
    {
      "serviceName": "nats",
      "serviceType": "Stateful",
      "dockerImage": "nats",
      "dockerTag": "2.12.8-alpine",
      "containerConfig": {
        "entrypoint": [
          "sh",
          "-c",
          "set -e; mkdir -p /etc/nats /data/accounts; printf '%s' \"$NATS_CONF\" > /etc/nats/nats.conf; if [ -n \"$NATS_ACCOUNTS_INDEX\" ]; then printf '%s\\n' \"$NATS_ACCOUNTS_INDEX\" | while IFS=' ' read -r pk jwt; do [ -n \"$pk\" ] && [ -n \"$jwt\" ] && printf '%s' \"$jwt\" > \"/data/accounts/$pk.jwt\"; done; fi; exec nats-server -c /etc/nats/nats.conf -m 8222"
        ],
        "dynamicEnv": {
          "NATS_CONF": {
            "kind": "vault-kv",
            "path": "shared/nats-config",
            "field": "conf"
          },
          "NATS_ACCOUNTS_INDEX": {
            "kind": "vault-kv",
            "path": "shared/nats-accounts-index",
            "field": "index"
          }
        },
        "ports": [
          {
            "containerPort": 4222,
            "hostPort": "{{params.nats-host-port}}",
            "protocol": "tcp",
            "exposeOnHost": true
          },
          {
            "containerPort": 8222,
            "hostPort": "{{params.nats-monitor-port}}",
            "protocol": "tcp",
            "exposeOnHost": true
          }
        ],
        "mounts": [
          {
            "source": "nats_data",
            "target": "/data",
            "type": "volume"
          }
        ],
        "restartPolicy": "unless-stopped",
        "joinResourceNetworks": ["nats"],
        "healthcheck": {
          "test": ["CMD", "wget", "-qO-", "http://localhost:8222/healthz"],
          "interval": 10,
          "timeout": 3,
          "retries": 5,
          "startPeriod": 10
        },
        "logConfig": {
          "type": "json-file",
          "maxSize": "10m",
          "maxFile": "3"
        }
      },
      "dependsOn": [],
      "order": 1
    }
  ]
}
