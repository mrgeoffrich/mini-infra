{
  "name": "cloudflare-tunnel",
  "displayName": "Cloudflare Tunnel",
  "builtinVersion": 8,
  "scope": "environment",
  "networkType": "internet",
  "category": "infrastructure",
  "description": "Cloudflare tunnel connector for exposing services to the internet via HAProxy",
  "resourceOutputs": [
    { "type": "docker-network", "purpose": "tunnel" }
  ],
  "parameters": [],
  "networks": [],
  "volumes": [],
  "services": [
    {
      "serviceName": "cloudflared",
      "serviceType": "Stateful",
      "dockerImage": "cloudflare/cloudflared",
      "dockerTag": "latest",
      "containerConfig": {
        "command": ["tunnel", "--no-autoupdate", "run"],
        "env": {
          "TUNNEL_METRICS": "127.0.0.1:2000"
        },
        "dynamicEnv": {
          "TUNNEL_TOKEN": { "kind": "cloudflare-tunnel-token" }
        },
        "requiredEgress": ["*.cloudflare.com", "*.argotunnel.com"],
        "joinResourceNetworks": ["tunnel"],
        "restartPolicy": "unless-stopped",
        "healthcheck": {
          "test": ["CMD", "cloudflared", "tunnel", "ready"],
          "interval": 30,
          "timeout": 5,
          "retries": 3,
          "startPeriod": 15
        },
        "logConfig": { "type": "json-file", "maxSize": "10m", "maxFile": "3" }
      },
      "dependsOn": [],
      "order": 1
    }
  ]
}
