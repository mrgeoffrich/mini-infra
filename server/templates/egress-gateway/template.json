{
  "name": "egress-gateway",
  "displayName": "Egress Gateway",
  "builtinVersion": 3,
  "scope": "environment",
  "category": "infrastructure",
  "description": "Smokescreen-based HTTP/HTTPS forward proxy for environment egress traffic control",
  "parameters": [
    {
      "name": "log-level",
      "type": "string",
      "default": "info",
      "description": "Log level for the egress gateway (debug, info, warn, error)"
    }
  ],
  "resourceInputs": [
    { "type": "docker-network", "purpose": "applications" }
  ],
  "networks": [],
  "volumes": [],
  "services": [
    {
      "serviceName": "egress-gateway",
      "serviceType": "Stateful",
      "dockerImage": "${EGRESS_GATEWAY_IMAGE_TAG}",
      "dockerTag": "latest",
      "containerConfig": {
        "egressBypass": true,
        "env": {
          "LOG_LEVEL": "{{params.log-level}}",
          "PROXY_PORT": "3128",
          "ADMIN_PORT": "8054"
        },
        "ports": [
          { "containerPort": 3128, "hostPort": 0, "protocol": "tcp", "exposeOnHost": false },
          { "containerPort": 8054, "hostPort": 0, "protocol": "tcp", "exposeOnHost": false }
        ],
        "restartPolicy": "unless-stopped",
        "joinResourceNetworks": ["applications"],
        "logConfig": { "type": "json-file", "maxSize": "10m", "maxFile": "3" }
      },
      "dependsOn": [],
      "order": 1
    }
  ]
}
