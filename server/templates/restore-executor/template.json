{
  "name": "restore-executor",
  "displayName": "PostgreSQL Restore",
  "builtinVersion": 1,
  "scope": "environment",
  "category": "infrastructure",
  "description": "JobPool-driven PostgreSQL restore runner. Manual-only trigger (one-shot restore per UI request). Restore parameters (target backup URL, target database) flow through `JOB_PAYLOAD` on the manual HTTP trigger; per-run env (POSTGRES_*, AZURE_SAS_URL, RESTORE=yes) is minted by the server's apply-time runtime env resolver. The template carries only the static framework wiring (image, dynamicEnv, NATS role, required egress).",
  "parameters": [],
  "requires": [
    { "kind": "stack", "templateName": "nats", "minState": "synced", "scopeMatch": "host" }
  ],
  "resourceInputs": [
    { "type": "docker-network", "purpose": "nats", "optional": false },
    { "type": "docker-network", "purpose": "database", "optional": false }
  ],
  "networks": [],
  "volumes": [],
  "nats": {
    "subjectPrefix": "mini-infra.restore",
    "roles": [
      {
        "name": "restore",
        "publish": [
          "progress.>"
        ],
        "subscribe": []
      }
    ]
  },
  "services": [
    {
      "serviceName": "restore-executor",
      "serviceType": "JobPool",
      "dockerImage": "${PG_BACKUP_TEMPLATE_IMAGE}",
      "dockerTag": "${PG_BACKUP_TEMPLATE_TAG}",
      "natsRole": "restore",
      "containerConfig": {
        "env": {
          "STACK_ID": "{{stack.id}}"
        },
        "dynamicEnv": {
          "NATS_URL": { "kind": "nats-url" },
          "NATS_CREDS": { "kind": "nats-creds" }
        },
        "joinResourceNetworks": ["nats", "database"],
        "requiredEgress": [
          "*.blob.core.windows.net",
          "*.dfs.core.windows.net",
          "login.microsoftonline.com",
          "oauth2.googleapis.com",
          "accounts.google.com",
          "www.googleapis.com"
        ],
        "logConfig": {
          "type": "json-file",
          "maxSize": "10m",
          "maxFile": "3"
        }
      },
      "jobPoolConfig": {
        "maxConcurrent": 1,
        "managedBy": null,
        "triggers": [],
        "history": { "retainDays": 30, "maxBytes": "1GiB" },
        "killAfterSeconds": 10800,
        "onFailure": { "retries": 0, "backoff": "fixed" }
      },
      "dependsOn": [],
      "order": 1
    }
  ]
}
