{
  "name": "monitoring",
  "displayName": "Monitoring Stack",
  "builtinVersion": 2,
  "scope": "host",
  "category": "infrastructure",
  "description": "Container metrics monitoring with Telegraf, Prometheus, and centralized log collection with Loki and Alloy",
  "parameters": [],
  "networks": [
    { "name": "monitoring_network", "driver": "bridge" }
  ],
  "volumes": [
    { "name": "prometheus_data" },
    { "name": "loki_data" }
  ],
  "services": [
    {
      "serviceName": "telegraf",
      "serviceType": "Stateful",
      "dockerImage": "telegraf",
      "dockerTag": "latest",
      "containerConfig": {
        "user": "root",
        "env": {},
        "entrypoint": [
          "sh", "-c",
          "chmod 666 /var/run/docker.sock && exec /entrypoint.sh telegraf --config /telegraf-volume/config/telegraf.conf"
        ],
        "ports": [
          { "containerPort": 9273, "hostPort": 9273, "protocol": "tcp" }
        ],
        "mounts": [
          { "source": "prometheus_data", "target": "/telegraf-volume", "type": "volume", "readOnly": true },
          { "source": "/var/run/docker.sock", "target": "/var/run/docker.sock", "type": "bind" }
        ],
        "restartPolicy": "unless-stopped",
        "healthcheck": {
          "test": ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:9273/metrics"],
          "interval": 30,
          "timeout": 3,
          "retries": 3,
          "startPeriod": 10
        },
        "logConfig": { "type": "json-file", "maxSize": "10m", "maxFile": "3" }
      },
      "dependsOn": [],
      "order": 1
    },
    {
      "serviceName": "prometheus",
      "serviceType": "Stateful",
      "dockerImage": "prom/prometheus",
      "dockerTag": "v3.3.0",
      "containerConfig": {
        "env": {},
        "command": [
          "--config.file=/prometheus/config/prometheus.yml",
          "--storage.tsdb.path=/prometheus/data",
          "--storage.tsdb.retention.time=30d",
          "--web.enable-lifecycle"
        ],
        "ports": [
          { "containerPort": 9090, "hostPort": 9090, "protocol": "tcp" }
        ],
        "mounts": [
          { "source": "prometheus_data", "target": "/prometheus", "type": "volume" }
        ],
        "restartPolicy": "unless-stopped",
        "healthcheck": {
          "test": ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:9090/-/healthy"],
          "interval": 30,
          "timeout": 3,
          "retries": 3,
          "startPeriod": 10
        },
        "logConfig": { "type": "json-file", "maxSize": "10m", "maxFile": "3" }
      },
      "initCommands": [
        {
          "volumeName": "prometheus_data",
          "mountPath": "/prometheus",
          "commands": [
            "mkdir -p /prometheus/config /prometheus/data",
            "chown -R 65534:65534 /prometheus/data"
          ]
        }
      ],
      "dependsOn": ["telegraf"],
      "order": 2
    },
    {
      "serviceName": "loki",
      "serviceType": "Stateful",
      "dockerImage": "grafana/loki",
      "dockerTag": "3.6.0",
      "containerConfig": {
        "env": {},
        "command": ["-config.file=/loki/config/local-config.yaml"],
        "ports": [
          { "containerPort": 3100, "hostPort": 3100, "protocol": "tcp" }
        ],
        "mounts": [
          { "source": "loki_data", "target": "/loki", "type": "volume" }
        ],
        "restartPolicy": "unless-stopped",
        "healthcheck": {
          "test": ["NONE"],
          "interval": 30,
          "timeout": 3,
          "retries": 3,
          "startPeriod": 30
        },
        "logConfig": { "type": "json-file", "maxSize": "10m", "maxFile": "3" }
      },
      "initCommands": [
        {
          "volumeName": "loki_data",
          "mountPath": "/loki",
          "commands": [
            "mkdir -p /loki/config /loki/rules /loki/chunks /loki/compactor",
            "chown -R 10001:10001 /loki"
          ]
        }
      ],
      "dependsOn": [],
      "order": 3
    },
    {
      "serviceName": "alloy",
      "serviceType": "Stateful",
      "dockerImage": "grafana/alloy",
      "dockerTag": "latest",
      "containerConfig": {
        "user": "root",
        "env": {},
        "command": [
          "run",
          "/loki/config/config.alloy",
          "--server.http.listen-addr=0.0.0.0:12345"
        ],
        "ports": [
          { "containerPort": 12345, "hostPort": 12345, "protocol": "tcp" }
        ],
        "mounts": [
          { "source": "loki_data", "target": "/loki", "type": "volume", "readOnly": true },
          { "source": "/var/run/docker.sock", "target": "/var/run/docker.sock", "type": "bind" }
        ],
        "restartPolicy": "unless-stopped",
        "healthcheck": {
          "test": ["CMD-SHELL", "bash -c \"echo > /dev/tcp/localhost/12345\" 2>/dev/null"],
          "interval": 30,
          "timeout": 3,
          "retries": 3,
          "startPeriod": 20
        },
        "logConfig": { "type": "json-file", "maxSize": "10m", "maxFile": "3" }
      },
      "dependsOn": ["loki"],
      "order": 4
    }
  ],
  "configFiles": [
    {
      "serviceName": "telegraf",
      "fileName": "telegraf.conf",
      "volumeName": "prometheus_data",
      "mountPath": "/config/telegraf.conf",
      "contentFile": "telegraf.conf"
    },
    {
      "serviceName": "prometheus",
      "fileName": "prometheus.yml",
      "volumeName": "prometheus_data",
      "mountPath": "/config/prometheus.yml",
      "contentFile": "prometheus.yml"
    },
    {
      "serviceName": "loki",
      "fileName": "loki.yaml",
      "volumeName": "loki_data",
      "mountPath": "/config/local-config.yaml",
      "contentFile": "loki.yaml"
    },
    {
      "serviceName": "alloy",
      "fileName": "alloy.alloy",
      "volumeName": "loki_data",
      "mountPath": "/config/config.alloy",
      "contentFile": "alloy.alloy"
    }
  ]
}
