{
  "name": "egress-fw-agent",
  "displayName": "Egress Firewall Agent",
  "builtinVersion": 6,
  "scope": "host",
  "category": "infrastructure",
  "description": "Blocks outbound network traffic that breaks your environment's egress rules. Runs once per host. Logs every blocked connection so you can see what was denied and why. Requires a synced NATS host stack (which transitively requires Vault to be bootstrapped).",
  "parameters": [
    {
      "name": "log-level",
      "type": "string",
      "default": "info",
      "description": "Log level for the fw-agent (debug, info, warn, error)"
    }
  ],
  "requires": [
    { "kind": "stack", "templateName": "nats", "minState": "synced", "scopeMatch": "host" }
  ],
  "networks": [],
  "volumes": [
    { "name": "nats_creds" }
  ],
  "nats": {
    "subjectPrefix": "mini-infra.egress.fw",
    "roles": [
      {
        "name": "agent",
        "publish": [
          "rules.applied",
          "events"
        ],
        "subscribe": [
          "rules.apply"
        ],
        "kvBuckets": [
          "egress-fw-health"
        ],
        "inboxAuto": "both",
        "ttlSeconds": 0
      }
    ]
  },
  "services": [
    {
      "serviceName": "egress-fw-agent",
      "serviceType": "Stateful",
      "dockerImage": "${EGRESS_FW_AGENT_IMAGE_TAG}",
      "dockerTag": "latest",
      "natsRole": "agent",
      "containerConfig": {
        "networkMode": "host",
        "capAdd": ["NET_ADMIN", "NET_RAW"],
        "egressBypass": true,
        "env": {
          "LOG_LEVEL": "{{params.log-level}}"
        },
        "dynamicEnv": {
          "NATS_URL": { "kind": "nats-url" },
          "NATS_CREDS_FILE": { "kind": "nats-creds-file" }
        },
        "mounts": [
          {
            "source": "/lib/modules",
            "target": "/lib/modules",
            "type": "bind",
            "readOnly": true
          },
          {
            "source": "nats_creds",
            "target": "/etc/nats-creds",
            "type": "volume",
            "readOnly": true
          }
        ],
        "labels": {
          "mini-infra.egress.fw-agent": "true"
        },
        "restartPolicy": "unless-stopped",
        "logConfig": {
          "type": "json-file",
          "maxSize": "10m",
          "maxFile": "3"
        }
      },
      "dependsOn": [],
      "order": 1
    }
  ]
}
