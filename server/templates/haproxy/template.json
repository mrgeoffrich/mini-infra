{
  "name": "haproxy",
  "displayName": "HAProxy Load Balancer",
  "builtinVersion": 3,
  "scope": "environment",
  "category": "infrastructure",
  "description": "HAProxy load balancer with DataPlane API",
  "parameters": [
    { "name": "http-port", "type": "number", "default": 80, "description": "Host port for HTTP traffic (0 to disable)" },
    { "name": "https-port", "type": "number", "default": 443, "description": "Host port for HTTPS traffic (0 to disable)" },
    { "name": "stats-port", "type": "number", "default": 8404, "description": "Host port for HAProxy stats (0 to disable)" },
    { "name": "dataplane-port", "type": "number", "default": 5555, "description": "Host port for DataPlane API (0 to disable)" }
  ],
  "networks": [
    { "name": "network", "driver": "bridge" }
  ],
  "volumes": [
    { "name": "haproxy_data" },
    { "name": "haproxy_run" },
    { "name": "haproxy_config" },
    { "name": "haproxy_certs" }
  ],
  "services": [
    {
      "serviceName": "haproxy",
      "serviceType": "Stateful",
      "dockerImage": "haproxytech/haproxy-alpine",
      "dockerTag": "3.2",
      "containerConfig": {
        "env": {
          "HAPROXY_DATACENTER": "docker",
          "HAPROXY_MWORKER": "1",
          "DATAPLANEAPI_USERLIST_FILE": "/usr/local/etc/haproxy/haproxy.cfg"
        },
        "ports": [
          { "containerPort": 80, "hostPort": "{{params.http-port}}", "protocol": "tcp" },
          { "containerPort": 443, "hostPort": "{{params.https-port}}", "protocol": "tcp" },
          { "containerPort": 8404, "hostPort": "{{params.stats-port}}", "protocol": "tcp" },
          { "containerPort": 5555, "hostPort": "{{params.dataplane-port}}", "protocol": "tcp" }
        ],
        "mounts": [
          { "source": "haproxy_config", "target": "/usr/local/etc/haproxy/", "type": "volume" },
          { "source": "haproxy_certs", "target": "/etc/ssl/certs", "type": "volume" }
        ],
        "restartPolicy": "unless-stopped",
        "healthcheck": {
          "test": ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://admin:admin@127.0.0.1:8404/stats"],
          "interval": 30,
          "timeout": 5,
          "retries": 3,
          "startPeriod": 10
        },
        "logConfig": { "type": "json-file", "maxSize": "10m", "maxFile": "3" }
      },
      "dependsOn": [],
      "order": 1
    }
  ],
  "configFiles": [
    {
      "serviceName": "haproxy",
      "fileName": "haproxy.cfg",
      "volumeName": "haproxy_config",
      "mountPath": "/haproxy.cfg",
      "contentFile": "haproxy.cfg",
      "permissions": "666"
    },
    {
      "serviceName": "haproxy",
      "fileName": "dataplaneapi.yml",
      "volumeName": "haproxy_config",
      "mountPath": "/dataplaneapi.yml",
      "contentFile": "dataplaneapi.yml",
      "permissions": "666"
    },
    {
      "serviceName": "haproxy",
      "fileName": "domain-backend.map",
      "volumeName": "haproxy_config",
      "mountPath": "/domain-backend.map",
      "contentFile": "domain-backend.map",
      "permissions": "666"
    }
  ]
}
