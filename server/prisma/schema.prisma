// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// User model for authentication
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  image           String?
  googleId        String?   @unique
  passwordHash    String?
  authMethod      String    @default("local") // "local", "google", "both"
  mustResetPwd    Boolean   @default(false)
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  apiKeys              ApiKey[]
  userPreference       UserPreference?
  postgresServers      PostgresServer[]
  userEvents           UserEvent[]
  agentConversations   AgentConversation[]
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model AuthSettings {
  id                   String   @id @default(cuid())
  googleOAuthEnabled   Boolean  @default(false)
  googleClientId       String?
  googleClientSecret   String?
  setupComplete        Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("auth_settings")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ApiKey model for webhook authentication.
// userId is nullable: null represents a system credential (e.g. the built-in
// agent sidecar key) that is not tied to any human user.
model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  userId      String?
  active      Boolean  @default(true)
  permissions String?  // JSON array of permission scopes, null = full access
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// UserPreference model for storing user-specific preferences
model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Container dashboard preferences
  containerSortField    String?  @default("name")
  containerSortOrder    String?  @default("asc")
  containerFilters      Json?    // Stored filter preferences
  containerColumns      Json?    // Visible columns configuration
  
  // User preferences
  timezone              String?  @default("UTC")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ContainerCache model for caching container data
model ContainerCache {
  id        String   @id @default(cuid())
  data      Json     // Cached container data
  expiresAt DateTime
  
  createdAt DateTime @default(now())
  
  @@index([expiresAt])
  @@map("container_cache")
}

// SystemSettings model for storing system configuration
model SystemSettings {
  id                    String   @id @default(cuid())
  category              String   // 'docker', 'cloudflare', 'azure'
  key                   String   // Specific setting key within category
  value                 String   // Encrypted value for sensitive data
  isEncrypted           Boolean  @default(false)
  isActive              Boolean  @default(true)
  lastValidatedAt       DateTime?
  validationStatus      String?  // 'valid', 'invalid', 'pending', 'error'
  validationMessage     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdBy            String   // User ID who created the setting
  updatedBy            String   // User ID who last updated the setting
  
  @@unique([category, key])
  @@index([category])
  @@index([validationStatus])
  @@index([isActive])
  @@map("system_settings")
}


// ConnectivityStatus model for tracking external service connectivity
model ConnectivityStatus {
  id                    String   @id @default(cuid())
  service               String   // 'cloudflare', 'docker', 'azure'
  status                String   // 'connected', 'failed', 'timeout', 'unreachable'
  responseTimeMs        BigInt?  // Response time in milliseconds for successful connections
  errorMessage          String?  // Detailed error message for failed connections
  errorCode             String?  // Service-specific error code
  lastSuccessfulAt      DateTime? // Last successful connection timestamp
  checkedAt             DateTime @default(now()) // When this check was performed
  checkInitiatedBy      String?  // User ID who initiated manual check (null for scheduled checks)
  
  // Service-specific metadata (JSON stored as string)
  metadata              String?  // Additional service-specific information
  
  @@index([service])
  @@index([status])
  @@index([checkedAt])
  @@index([service, checkedAt])
  @@map("connectivity_status")
}

// PostgreSQL Database Management Models

// PostgresDatabase model for managing database configurations
model PostgresDatabase {
  id               String   @id @default(cuid())
  name             String   @unique
  connectionString String   // Encrypted
  host             String
  port             Int
  database         String
  username         String
  sslMode          String   @default("prefer")
  tags             String   // JSON array
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastHealthCheck  DateTime?
  healthStatus     String   @default("unknown")

  backupConfig     BackupConfiguration?
  backupOperations BackupOperation[]
  restoreOperations RestoreOperation[]

  @@map("postgres_databases")
}

// BackupConfiguration model for managing backup scheduling and settings
model BackupConfiguration {
  id                String   @id @default(cuid())
  databaseId        String   @unique
  database          PostgresDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  schedule          String?  // Cron expression
  timezone          String   @default("UTC")
  // Provider-agnostic location: Azure container name OR Drive folder ID.
  storageLocationId String   @default("")
  // Per-config path prefix within the location.
  storagePathPrefix String   @default("")
  retentionDays     Int      @default(30)
  backupFormat      String   @default("custom")
  compressionLevel  Int      @default(6)
  isEnabled         Boolean  @default(true)
  lastBackupAt      DateTime?
  nextScheduledAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([databaseId])
  @@map("backup_configurations")
}

// BackupOperation model for tracking backup job execution
model BackupOperation {
  id              String   @id @default(cuid())
  databaseId      String
  database        PostgresDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  operationType   String   // manual, scheduled
  status          String   // pending, running, completed, failed
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  sizeBytes       BigInt?
  // Provider-agnostic backend URL (Azure blob URL, Drive file webViewLink, ...).
  storageObjectUrl String?
  // Captured at write time so a later restore can resolve the right backend
  // even if the active provider has since switched.
  storageProviderAtCreation String  @default("azure")
  errorMessage    String?
  progress        Int      @default(0)
  metadata        String?  // JSON for additional data

  @@index([databaseId, status])
  @@index([startedAt])
  @@map("backup_operations")
}

// RestoreOperation model for tracking restore job execution
model RestoreOperation {
  id              String   @id @default(cuid())
  databaseId      String
  database        PostgresDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  backupUrl       String
  status          String   // pending, running, completed, failed
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  errorMessage    String?
  progress        Int      @default(0)
  
  @@index([databaseId, status])
  @@map("restore_operations")
}

// Self-Backup Model for Mini Infra database backups
model SelfBackup {
  id                String   @id @default(cuid())
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  status            String   // 'in_progress', 'completed', 'failed'
  filePath          String?  // Temp file path during backup
  storageObjectUrl  String?  // Provider-agnostic URL after successful upload
  storageLocationId String   @default("") // Azure container name OR Drive folder ID
  // Captured at write time — restore uses this to look up the right backend.
  storageProviderAtCreation String   @default("azure")
  fileName          String   // mini-infra-{timestamp}.db.zip
  fileSize          Int?     // Bytes
  errorMessage      String?
  errorCode         String?
  triggeredBy       String   // 'scheduled' or 'manual'
  userId            String?  // If manual trigger
  durationMs        Int?     // Backup duration in milliseconds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startedAt])
  @@index([storageLocationId])
  @@map("self_backups")
}


// Environment Management Models

// Environment model - Core entity for managing service collections
model Environment {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  type        String   // 'production', 'nonproduction'
  networkType      String   @default("local") // 'local', 'internet'
  tunnelId         String?  // Cloudflare tunnel UUID for internet environments
  tunnelServiceUrl String?  // HAProxy URL the tunnel routes to
  createdAt        DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Egress firewall — populated after the egress-gateway stack first applies
  egressGatewayIp  String?

  // Phase 2: per-env egress firewall flag (default OFF).
  // When true, EnvFirewallManager calls the fw-agent for this environment.
  egressFirewallEnabled Boolean @default(false)

  // Relations
  networks    EnvironmentNetwork[]
  haproxyFrontends HAProxyFrontend[]
  haproxyBackends  HAProxyBackend[]
  stacks           Stack[]
  stackTemplates   StackTemplate[]
  infraResources   InfraResource[]
  egressPolicies   EgressPolicy[]

  @@index([type])
  @@index([networkType])
  @@map("environments")
}

// EnvironmentNetwork - Tracks Docker networks for environments
model EnvironmentNetwork {
  id            String   @id @default(cuid())
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  name          String
  purpose       String   @default("custom") // 'applications', 'tunnel', 'custom'
  driver        String   @default("bridge")
  options       Json?    // Network options
  dockerId      String?  // Docker network ID when created
  createdAt     DateTime @default(now())

  @@unique([environmentId, name])
  @@unique([environmentId, purpose])
  @@index([environmentId])
  @@map("environment_networks")
}

// HostService model - Tracks host-level services (not scoped to an environment)
model HostService {
  id          String   @id @default(cuid())
  serviceName String   @unique  // e.g., "monitoring"
  serviceType String              // e.g., "MonitoringService"
  status      String   @default("stopped")
  health      String   @default("unknown")
  config      Json?    // Service-specific configuration
  startedAt   DateTime?
  stoppedAt   DateTime?
  lastError   Json?    // Error details
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@map("host_services")
}

// HAProxyFrontend model for tracking HAProxy frontends
model HAProxyFrontend {
  id                    String   @id @default(cuid())

  // Frontend type discriminator
  frontendType          String   @default("shared") // "manual" | "shared"

  // Manual frontend fields
  containerName         String?  // Docker container name (for manual frontends)
  containerId           String?  // Docker container ID (for manual frontends)
  containerPort         Int?     // Container listening port (for manual frontends)
  environmentId         String?  // Environment association

  // Environment relation
  environment           Environment? @relation(fields: [environmentId], references: [id])

  // Frontend configuration
  frontendName          String   @unique
  backendName           String
  hostname              String
  bindPort              Int      @default(80)
  bindAddress           String   @default("*")
  useSSL                Boolean  @default(false)

  // TLS/SSL configuration
  tlsCertificateId      String?  // Associated TLS certificate
  tlsCertificate        TlsCertificate? @relation(fields: [tlsCertificateId], references: [id])
  sslBindPort           Int      @default(443)

  // Shared frontend support
  isSharedFrontend      Boolean  @default(false)
  sharedFrontendId      String?  // Reference to parent shared frontend (for routes)

  // Relations
  routes                HAProxyRoute[]

  status                String   @default("pending") // 'active', 'pending', 'failed', 'removed'
  errorMessage          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([frontendName])
  @@index([hostname])
  @@index([status])
  @@index([tlsCertificateId])
  @@index([frontendType])
  @@index([environmentId])
  @@index([isSharedFrontend])
  @@map("haproxy_frontends")
}

// HAProxyRoute model for tracking individual hostname routes within a shared frontend
model HAProxyRoute {
  id                    String   @id @default(cuid())
  sharedFrontendId      String   // FK to shared HAProxyFrontend
  sharedFrontend        HAProxyFrontend @relation(fields: [sharedFrontendId], references: [id], onDelete: Cascade)

  // Route configuration
  hostname              String
  aclName               String   // e.g., "acl_pilltracker_app"
  backendName           String   // e.g., "pilltracker"
  priority              Int      @default(0)  // For rule ordering

  // Source tracking
  sourceType            String   // "manual" | "stack"
  manualFrontendId      String?  // For manual routes (legacy migration)

  // SSL per-route (for SNI)
  useSSL                Boolean  @default(false)
  tlsCertificateId      String?

  status                String   @default("active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([sharedFrontendId, hostname])
  @@index([sharedFrontendId])
  @@index([hostname])
  @@index([status])
  @@index([sourceType])
  @@map("haproxy_routes")
}

// HAProxyBackend model for tracking HAProxy backend configurations
model HAProxyBackend {
  id                    String   @id @default(cuid())
  name                  String   // Backend name in HAProxy
  environmentId         String
  environment           Environment @relation(fields: [environmentId], references: [id])

  // Backend configuration
  mode                  String   @default("http") // "http" | "tcp"
  balanceAlgorithm      String   @default("roundrobin") // "roundrobin" | "leastconn" | "source"
  checkTimeout          Int?     // Health check timeout in ms
  connectTimeout        Int?     // Connection timeout in ms
  serverTimeout         Int?     // Server timeout in ms

  // Source tracking
  sourceType            String   // "manual" | "stack"
  manualFrontendId      String?  // For manually-created backends

  // Status tracking
  status                String   @default("active") // "active" | "failed"
  errorMessage          String?

  // Relations
  servers               HAProxyServer[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([name, environmentId])
  @@index([environmentId])
  @@index([status])
  @@index([sourceType])
  @@map("haproxy_backends")
}

// HAProxyServer model for tracking HAProxy server configurations within backends
model HAProxyServer {
  id                    String   @id @default(cuid())
  name                  String   // Server name in HAProxy
  backendId             String
  backend               HAProxyBackend @relation(fields: [backendId], references: [id], onDelete: Cascade)

  // Server configuration
  address               String   // Container name or IP address
  port                  Int
  check                 String   @default("enabled") // "enabled" | "disabled"
  checkPath             String?  // Health check endpoint
  inter                 Int?     // Health check interval in ms
  rise                  Int?     // Consecutive successful checks to mark UP
  fall                  Int?     // Consecutive failed checks to mark DOWN
  weight                Int      @default(100)
  enabled               Boolean  @default(true)
  maintenance           Boolean  @default(false)

  // Container tracking
  containerId           String?  // Docker container ID
  containerName         String?  // Docker container name
  // Status tracking
  status                String   @default("active") // "active" | "draining"
  errorMessage          String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([name, backendId])
  @@index([backendId])
  @@index([status])
  @@index([containerId])
  @@map("haproxy_servers")
}

// Registry Credentials Management

// RegistryCredential model for managing Docker registry authentication
model RegistryCredential {
  id                    String   @id @default(cuid())
  name                  String   // Friendly name (e.g., "GitHub Container Registry", "Docker Hub Production")
  registryUrl           String   // Registry address (e.g., "ghcr.io", "registry.hub.docker.com")
  username              String   // Registry username
  password              String   // Encrypted password
  isDefault             Boolean  @default(false) // Default registry for unmatched images
  isActive              Boolean  @default(true)  // Enable/disable without deletion

  // Metadata
  description           String?  // Optional description
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdBy             String   // User ID
  updatedBy             String   // User ID

  // Token expiry tracking (for auto-managed credentials like GHCR)
  tokenExpiresAt        DateTime?

  // Validation tracking
  lastValidatedAt       DateTime?
  validationStatus      String?  // 'valid', 'invalid', 'pending', 'error'
  validationMessage     String?

  @@unique([registryUrl])
  @@map("registry_credentials")
}

// PostgreSQL Server Management Models (Phase 1.1)

// PostgresServer model for managing PostgreSQL server connections with admin credentials
model PostgresServer {
  id                String   @id @default(cuid())
  name              String   @unique // User-friendly name
  host              String
  port              Int      @default(5432)
  adminUsername     String   // Admin user (e.g., 'postgres')
  connectionString  String   // Encrypted connection string with admin password
  sslMode           String   @default("prefer") // prefer/require/disable
  tags              String?  // JSON array of tags

  // Health monitoring
  healthStatus      String   @default("unknown") // healthy/unhealthy/unknown
  lastHealthCheck   DateTime?
  serverVersion     String?  // e.g., "PostgreSQL 15.3"
  
  // Container linking (optional)
  linkedContainerId   String?  // Docker container ID
  linkedContainerName String?  // Docker container name (for display)

  // Metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relationships
  databases         ManagedDatabase[]
  users             ManagedDatabaseUser[]

  @@index([userId])
  @@index([healthStatus])
  @@map("postgres_servers")
}

// ManagedDatabase model for tracking databases managed on a PostgreSQL server
model ManagedDatabase {
  id               String   @id @default(cuid())
  serverId         String
  server           PostgresServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  // Database info
  databaseName     String   // Name on the server
  owner            String   // Database owner role
  encoding         String   @default("UTF8")
  collation        String?
  template         String   @default("template0")

  // Metadata from server
  sizeBytes        BigInt?  // Database size
  connectionLimit  Int      @default(-1) // -1 = unlimited

  // Tracking
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastSyncedAt     DateTime? // Last time we synced with server

  // Relationships
  grants           DatabaseGrant[]

  @@unique([serverId, databaseName])
  @@index([serverId])
  @@map("managed_databases")
}

// ManagedDatabaseUser model for tracking users/roles on a PostgreSQL server
model ManagedDatabaseUser {
  id              String   @id @default(cuid())
  serverId        String
  server          PostgresServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  // User info
  username        String
  canLogin        Boolean  @default(true)
  isSuperuser     Boolean  @default(false)
  connectionLimit Int      @default(-1)

  // Password management
  passwordHash    String?  // Encrypted - for our records only
  passwordSetAt   DateTime?

  // Tracking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSyncedAt    DateTime?

  // Relationships
  grants          DatabaseGrant[]

  @@unique([serverId, username])
  @@index([serverId])
  @@map("managed_database_users")
}

// DatabaseGrant model for tracking permissions granted to users on databases
model DatabaseGrant {
  id          String   @id @default(cuid())
  databaseId  String
  database    ManagedDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  userId      String
  user        ManagedDatabaseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Permissions
  canConnect  Boolean  @default(true)
  canCreate   Boolean  @default(false)
  canTemp     Boolean  @default(false)

  // Schema-level privileges (on public schema)
  canCreateSchema   Boolean @default(false)
  canUsageSchema    Boolean @default(true)

  // Table-level privileges (ALL TABLES)
  canSelect   Boolean  @default(true)
  canInsert   Boolean  @default(true)
  canUpdate   Boolean  @default(true)
  canDelete   Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([databaseId, userId])
  @@index([databaseId])
  @@index([userId])
  @@map("database_grants")
}

// TLS Certificate Management Models

/// Managed TLS certificate records
model TlsCertificate {
  id                    String   @id @default(cuid())

  // Certificate identification
  domains               String   // JSON array of domains (e.g., ["example.com", "*.example.com"])
  primaryDomain         String   // Main domain for certificate
  certificateType       CertificateType @default(ACME) // "ACME" | "MANUAL"

  // ACME-specific fields
  acmeProvider          String?  // "letsencrypt" | "buypass" | "zerossl"
  acmeAccountId         String?  // ACME account identifier
  acmeOrderUrl          String?  // ACME order URL for renewals

  // Azure Blob Storage references (optional during migration from Key Vault)
  blobContainerName     String?  // Azure Storage container name
  blobName              String?  @unique // Blob name (cert_{id}.pem)

  // Certificate metadata
  issuer                String?
  serialNumber          String?
  fingerprint           String?  @unique

  // Lifecycle dates
  issuedAt              DateTime
  notBefore             DateTime
  notAfter              DateTime
  renewAfter            DateTime // Calculated: notAfter - renewalDaysBeforeExpiry
  lastRenewedAt         DateTime?

  // Status tracking
  status                CertificateStatus @default(PENDING) // "PENDING" | "ACTIVE" | "RENEWING" | "EXPIRED" | "REVOKED" | "ERROR"
  lastError             String?
  lastErrorAt           DateTime?

  // Configuration
  autoRenew             Boolean  @default(true)
  renewalDaysBeforeExpiry Int   @default(30)

  // Associated HAProxy frontends (legacy JSON field - deprecated in favor of relation)
  haproxyFrontendNames  String?  // JSON array of frontend names using this cert

  // Audit trail
  createdBy             String
  updatedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  renewalHistory        TlsCertificateRenewal[]
  haproxyFrontends      HAProxyFrontend[]

  @@index([primaryDomain])
  @@index([status])
  @@index([renewAfter])
  @@index([notAfter])
  @@map("tls_certificates")
}

/// Certificate renewal history and audit log
model TlsCertificateRenewal {
  id              String   @id @default(cuid())
  certificateId   String
  certificate     TlsCertificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  // Renewal attempt details
  attemptNumber   Int      // Retry attempt number (1, 2, 3...)
  status          RenewalStatus // "INITIATED" | "DNS_CHALLENGE_CREATED" | "CHALLENGE_VALIDATED" | "CERTIFICATE_ISSUED" | "STORED_IN_VAULT" | "DEPLOYED_TO_HAPROXY" | "COMPLETED" | "FAILED"

  // Timing
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  durationMs      Int?

  // ACME details
  acmeOrderUrl    String?
  acmeChallengeType String? // "dns-01"
  dnsRecordName   String?  // e.g., "_acme-challenge.example.com"
  dnsRecordValue  String?

  // Azure Blob Storage details
  blobETag        String?  // New ETag after upload to Azure Storage

  // HAProxy deployment
  haproxyReloadMethod String? // "runtime-api" | "graceful-reload"
  haproxyReloadSuccess Boolean @default(false)

  // Error tracking
  errorMessage    String?
  errorCode       String?
  errorDetails    String?  // JSON stringified detailed error

  // Metadata
  triggeredBy     String   // "auto-renewal" | "manual" | userId
  metadata        String?  // JSON stringified additional data

  @@index([certificateId])
  @@index([status])
  @@index([startedAt])
  @@map("tls_certificate_renewals")
}

/// ACME account management
model AcmeAccount {
  id              String   @id @default(cuid())

  // Account identification
  email           String   @unique
  provider        String   // "letsencrypt" | "letsencrypt-staging" | "buypass" | "zerossl"
  accountUrl      String   @unique // ACME account URL

  // Key storage in Azure Blob Storage (optional during migration from Key Vault)
  blobContainerName String? // Azure Storage container name
  blobName        String?  @unique // Blob name (acme-account-{email}.key)
  keyAlgorithm    String   @default("RSA-2048") // "RSA-2048" | "ECDSA-P256"

  // Status
  status          String   @default("ACTIVE") // "ACTIVE" | "DEACTIVATED"
  termsOfServiceUrl String?
  agreedToTermsAt DateTime?

  // Audit
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([provider])
  @@map("acme_accounts")
}

// Permission Preset Management

model PermissionPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  permissions String   // JSON array, e.g. ["containers:read","*"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permission_presets")
}

// User Events - Centralized event tracking for long-running operations

/// UserEvent model for tracking logs and outcomes of important long-running processes
model UserEvent {
  id                String   @id @default(cuid())

  // Event classification
  eventType         String   // 'deployment', 'environment_start', 'environment_stop', 'certificate_create', 'certificate_renew', 'backup', 'restore', 'container_cleanup', etc.
  eventCategory     String   // 'infrastructure', 'database', 'security', 'maintenance'
  eventName         String   // Human-readable name

  // User/trigger information
  userId            String?  // User who triggered (nullable for automated events)
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  triggeredBy       String   // 'manual', 'scheduled', 'webhook', 'api'

  // Status tracking
  status            String   // 'pending', 'running', 'completed', 'failed', 'cancelled'
  progress          Int      @default(0) // 0-100 percentage

  // Timing
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  durationMs        Int?     // Duration in milliseconds

  // Resource identification (optional, for linking to specific resources)
  resourceId        String?  // ID of deployment config, database, container, environment, certificate, etc.
  resourceType      String?  // 'deployment', 'database', 'container', 'certificate', 'environment'
  resourceName      String?  // Human-readable resource name

  // Detailed information
  description       String?  // Brief description
  metadata          String?  // JSON stringified flexible metadata (config, parameters, steps, etc.)

  // Output/results
  resultSummary     String?  // Brief result description
  errorMessage      String?  // Error message if failed
  errorDetails      String?  // JSON stringified detailed error information

  // Logs/output - Full text logs stored directly
  logs              String?  // Text logs (may contain newlines, structured log entries, etc.)

  // Retention
  expiresAt         DateTime? // Optional expiration for auto-cleanup

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([eventType])
  @@index([eventCategory])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@index([resourceType, resourceId])
  @@index([expiresAt])
  @@map("user_events")
}

// Volume Inspection - Stores the latest inspection results for Docker volumes

/// VolumeInspection model for tracking Docker volume file system inspection results
model VolumeInspection {
  id              String   @id @default(cuid())

  // Volume identification
  volumeName      String   @unique // Docker volume name

  // Inspection status
  status          String   // 'pending', 'running', 'completed', 'failed'

  // Timing
  inspectedAt     DateTime @default(now())
  completedAt     DateTime?
  durationMs      Int?     // Inspection duration in milliseconds

  // Results
  fileCount       Int?     // Total number of files found
  totalSize       BigInt?  // Total size in bytes
  files           String?  // JSON array of file information (path, size, permissions, owner, modified timestamp)

  // Output
  stdout          String?  // Standard output from inspection container
  stderr          String?  // Standard error from inspection container

  // Error tracking
  errorMessage    String?  // Error message if failed

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([volumeName])
  @@index([status])
  @@index([inspectedAt])
  @@map("volume_inspections")
}

// Volume File Content - Stores cached file contents from volume inspections

/// VolumeFileContent model for storing individual file contents from volume inspections
model VolumeFileContent {
  id              String   @id @default(cuid())

  // File identification
  volumeName      String   // Docker volume name
  filePath        String   // File path within volume (e.g., "/app/config.json")

  // File content and metadata
  content         String   // Text content (up to 1MB, base64-decoded from Alpine output)
  size            Int      // Original file size in bytes

  // Timing
  fetchedAt       DateTime @default(now())

  // Error tracking (if fetch failed for this specific file)
  errorMessage    String?  // Error message if fetch failed

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([volumeName, filePath]) // One content record per file per volume
  @@index([volumeName])
  @@index([fetchedAt])
  @@map("volume_file_contents")
}

// Agent Conversations - Persisted AI assistant chat history

/// AgentConversation model for storing per-user AI assistant conversation threads
model AgentConversation {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String    // First ~80 chars of first user message
  sdkSessionId   String?   // Agent SDK session ID for resume
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // Soft-delete timestamp; null = active

  messages  AgentConversationMessage[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([deletedAt])
  @@map("agent_conversations")
}

/// AgentConversationMessage model for storing individual messages in an agent conversation
model AgentConversationMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String            // 'user' | 'assistant' | 'tool_use' | 'error' | 'result'
  content        String?           // Text content for user/assistant/error messages
  toolId         String?
  toolName       String?
  toolInput      String?           // JSON stringified tool input
  toolOutput     String?
  success        Boolean?
  cost           Float?
  duration       Float?
  turns          Int?
  sequence       Int               // Monotonic ordering counter per conversation
  createdAt      DateTime          @default(now())

  @@index([conversationId])
  @@index([conversationId, sequence])
  @@map("agent_conversation_messages")
}

// Self-Update tracking - persists update state across container restarts

/// SelfUpdate model for tracking self-update operations
model SelfUpdate {
  id              String   @id @default(cuid())
  targetTag       String   // Target image tag (e.g., "v2.1.0")
  fullImageRef    String   // Full image reference (e.g., "ghcr.io/user/repo:v2.1.0")
  state           String   // 'pending', 'pulling', 'inspecting', 'stopping', 'creating', 'health-checking', 'complete', 'rolling-back', 'rollback-complete', 'failed'
  progress        Int?     // 0-100 for image pull progress
  errorMessage    String?
  sidecarId       String?  // Docker container ID of the sidecar

  // Timing
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  durationMs      Int?

  // Audit
  triggeredBy     String   // User ID who triggered the update
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([state])
  @@index([startedAt])
  @@map("self_updates")
}

// Enums
enum CertificateType {
  ACME    // Let's Encrypt via ACME protocol
  MANUAL  // Manually uploaded certificate
}

enum CertificateStatus {
  PENDING   // Certificate order initiated
  ACTIVE    // Certificate issued and active
  RENEWING  // Renewal in progress
  EXPIRED   // Certificate expired
  REVOKED   // Certificate revoked
  ERROR     // Error state
}

enum RenewalStatus {
  INITIATED
  DNS_CHALLENGE_CREATED
  DNS_CHALLENGE_VALIDATED
  CERTIFICATE_ISSUED
  STORED_IN_VAULT
  DEPLOYED_TO_HAPROXY
  COMPLETED
  FAILED
}

enum StackStatus {
  synced
  drifted
  pending
  error
  undeployed
  removed
}

enum StackServiceType {
  Stateful
  StatelessWeb
  AdoptedWeb
  Pool
}

enum StackTemplateSource {
  system
  user
}

enum StackTemplateScope {
  host
  environment
  any
}

enum StackTemplateVersionStatus {
  draft
  published
  archived
}

// Stack - Declarative container group definition
model Stack {
  id                   String      @id @default(cuid())
  name                 String
  description          String?
  environmentId        String?
  environment          Environment? @relation(fields: [environmentId], references: [id])
  version              Int         @default(1)
  status               StackStatus @default(undeployed)
  lastAppliedVersion   Int?
  lastAppliedAt        DateTime?
  lastAppliedSnapshot  Json?
  builtinVersion       Int?
  templateId           String?
  template             StackTemplate? @relation(fields: [templateId], references: [id])
  templateVersion      Int?        // Version number of the template used to create/sync this stack
  parameters           Json?       // Array of StackParameterDefinition
  parameterValues      Json?       // Record<string, string | number | boolean>
  networks             Json        // Array of { name, driver?, options? }
  volumes              Json        // Array of { name, driver?, options? }
  tlsCertificates      Json?       // Array of StackTlsCertificate
  dnsRecords           Json?       // Array of StackDnsRecord
  tunnelIngress        Json?       // Array of StackTunnelIngress
  resourceOutputs      Json?       // Array of StackResourceOutput
  resourceInputs       Json?       // Array of StackResourceInput
  removedAt            DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Vault binding (Phase 3). `lastAppliedVaultAppRoleId` is the AppRole ID
  // that was in effect on the last successful apply — compared against the
  // current `vaultAppRoleId` by the credential injector to decide whether
  // fail-closed degradation is allowed.
  vaultAppRoleId              String?
  vaultAppRole                VaultAppRole? @relation("StackVaultAppRole", fields: [vaultAppRoleId], references: [id], onDelete: SetNull)
  vaultFailClosed             Boolean       @default(true)
  lastAppliedVaultAppRoleId   String?
  lastAppliedNatsSnapshot     String?

  // Phase 2 — AES-256-GCM encrypted JSON blob of operator-supplied input values.
  // Never returned via API; GET /stacks/:id returns inputValueKeys (names only).
  encryptedInputValues        String?

  // Phase 2/4 — AES-256-GCM encrypted snapshot blob. Stores SnapshotV2 JSON
  // (policies, appRoles, kv with concrete bodies + hashes). Encrypted with the
  // same domain-separated key as encryptedInputValues. Never returned via API.
  // Column changed from Json? to String? in phase 4 to carry encrypted blobs.
  lastAppliedVaultSnapshot    String?

  // Populated when the Vault pre-service phase fails; cleared on success.
  lastFailureReason           String?

  // Relations
  services             StackService[]
  deployments          StackDeployment[]
  resources            StackResource[]
  infraResources       InfraResource[]
  poolInstances        PoolInstance[]

  vaultResources       StackVaultResource[]
  natsResources        StackNatsResource[]
  natsSigningKeys      NatsSigningKey[]     @relation("StackNatsSigningKey")
  natsCredentialProfiles NatsCredentialProfile[] @relation("StackNatsCredentialProfile")
  egressPolicies       EgressPolicy[]

  @@index([environmentId])
  @@index([status])
  @@index([templateId])
  @@index([vaultAppRoleId])
  @@map("stacks")
}

/// StackVaultResource — index of concrete Vault objects owned by a stack after apply.
/// Populated on every successful apply; used by the delete cascade to determine
/// which resources are safe to remove vs. shared by another stack.
model StackVaultResource {
  id           String  @id @default(cuid())
  stackId      String
  stack        Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)
  type         String  // "policy" | "approle" | "kv"
  concreteName String  // for kv: the path
  scope        String? // "host" | "environment" | "stack" | null (kv entries have no scope)

  @@unique([stackId, type, concreteName])
  @@index([type, concreteName])
  @@map("stack_vault_resources")
}

/// StackNatsResource — index of concrete NATS objects owned by a stack after apply.
model StackNatsResource {
  id           String  @id @default(cuid())
  stackId      String
  stack        Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)
  type         String  // "account" | "credential" | "stream" | "consumer"
  concreteName String
  scope        String? // "host" | "environment" | "stack" | null

  @@unique([stackId, type, concreteName])
  @@index([type, concreteName])
  @@map("stack_nats_resources")
}

// Vault Management Models

/// VaultState - Singleton row of encrypted state for the managed OpenBao instance
model VaultState {
  id                          String    @id @default(cuid())
  kind                        String    @unique   // "primary" for MVP; enables multi-vault later
  stackId                     String?
  address                     String?
  initialised                 Boolean   @default(false)
  initialisedAt               DateTime?
  bootstrappedAt              DateTime?
  // Passphrase KDF salt + probe (encrypted known value used to verify unlock)
  passphraseSalt              Bytes?
  passphraseProbe             Bytes?
  // Wrapped long-lived secrets (AES-GCM wrapped with the operator-passphrase-derived key)
  encryptedUnsealKeys         Bytes?
  encryptedRootToken          Bytes?
  encryptedAdminRoleId        Bytes?
  encryptedAdminSecretId      Bytes?
  encryptedAdminSecretIdAt    DateTime?
  encryptedOperatorPassword   Bytes?    // userpass mini-infra-operator password (P2)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@map("vault_state")
}

/// VaultPolicy - HCL policies managed by Mini Infra, with draft/publish semantics
model VaultPolicy {
  id                String        @id @default(cuid())
  name              String        @unique
  displayName       String
  description       String?
  draftHclBody      String?
  publishedHclBody  String?
  publishedVersion  Int           @default(0)
  publishedAt       DateTime?
  lastAppliedAt     DateTime?
  isSystem          Boolean       @default(false)
  createdById       String?
  updatedById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  appRoles          VaultAppRole[]

  @@index([isSystem])
  @@map("vault_policies")
}

/// VaultAppRole - AppRole definitions; Mini Infra reconciles to Vault on apply
model VaultAppRole {
  id              String       @id @default(cuid())
  name            String       @unique
  policyId        String
  policy          VaultPolicy  @relation(fields: [policyId], references: [id], onDelete: Restrict)
  secretIdNumUses Int          @default(1)
  secretIdTtl     String       @default("0")
  tokenTtl        String?
  tokenMaxTtl     String?
  tokenPeriod     String?
  cachedRoleId    String?      // captured after apply; nullable until reconciled
  lastAppliedAt   DateTime?
  createdById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  stacks                  Stack[]                @relation("StackVaultAppRole")
  stackServices           StackService[]         @relation("ServiceVaultAppRole")
  stackTemplateServices   StackTemplateService[] @relation("TemplateServiceVaultAppRole")

  @@index([policyId])
  @@map("vault_app_roles")
}

// NATS Management Models

/// NatsState - Singleton row for the managed NATS instance from the vault-nats stack
model NatsState {
  id                    String    @id @default(cuid())
  kind                  String    @unique
  stackId               String?
  clientUrl             String?
  /// Host-loopback NATS URL (e.g. nats://127.0.0.1:4222). Used by services
  /// running in `network_mode: host` (egress-fw-agent), where the docker-DNS
  /// `clientUrl` cannot resolve. Populated by `applyConfig()` from the
  /// vault-nats stack's `nats-host-port` parameter; nullable until the
  /// vault-nats stack is applied at least once.
  clientHostUrl         String?
  monitorUrl            String?
  bootstrappedAt        DateTime?
  lastAppliedAt         DateTime?
  operatorPublic        String?
  systemAccountPublic   String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("nats_state")
}

/// NatsAccount - NATS account material managed by Mini Infra, with seeds stored in Vault KV
model NatsAccount {
  id              String                  @id @default(cuid())
  name            String                  @unique
  displayName     String
  description     String?
  isSystem        Boolean                 @default(false)
  seedKvPath      String
  publicKey       String?
  jwt             String?
  lastAppliedAt   DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  credentialProfiles NatsCredentialProfile[]
  streams             NatsStream[]
  signingKeys         NatsSigningKey[]

  @@index([isSystem])
  @@map("nats_accounts")
}

/// NatsCredentialProfile - Reusable scoped credentials minted from a NATS account seed
model NatsCredentialProfile {
  id              String        @id @default(cuid())
  name            String        @unique
  displayName     String
  description     String?
  accountId       String
  account         NatsAccount   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  // Owning stack — populated by `materializeRole` during apply. Used by the
  // diff-and-prune step to clean up orphan profiles when a role is renamed
  // or removed from a template. Backfilled from the `<stackId>-<roleName>`
  // naming convention for rows created before this column existed.
  stackId         String?
  stack           Stack?        @relation("StackNatsCredentialProfile", fields: [stackId], references: [id], onDelete: Cascade)
  publishAllow    Json
  subscribeAllow  Json
  ttlSeconds      Int           @default(3600)
  lastAppliedAt   DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  stackServices           StackService[]         @relation("ServiceNatsCredential")
  stackTemplateServices   StackTemplateService[] @relation("TemplateServiceNatsCredential")

  @@index([accountId])
  @@index([stackId])
  @@map("nats_credential_profiles")
}

/// NatsStream - JetStream stream definitions owned by Mini Infra
model NatsStream {
  id              String          @id @default(cuid())
  name            String          @unique
  accountId       String
  account         NatsAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  description     String?
  subjects        Json
  retention       String          @default("limits")
  storage         String          @default("file")
  maxMsgs         Int?
  maxBytes        Int?
  maxAgeSeconds   Int?
  lastAppliedAt   DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  consumers       NatsConsumer[]

  @@index([accountId])
  @@map("nats_streams")
}

/// NatsConsumer - JetStream consumer definitions owned by Mini Infra
model NatsConsumer {
  id              String      @id @default(cuid())
  streamId        String
  stream          NatsStream  @relation(fields: [streamId], references: [id], onDelete: Cascade)
  name            String
  durableName     String?
  description     String?
  filterSubject   String?
  deliverPolicy   String      @default("all")
  ackPolicy       String      @default("explicit")
  maxDeliver      Int?
  ackWaitSeconds  Int?
  lastAppliedAt   DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([streamId, name])
  @@index([streamId])
  @@map("nats_consumers")
}

/// NatsSigningKey - Scoped signing keys bound to a stack via the new
/// `nats.signers[]` template surface. The seed itself is stored in Vault KV
/// at `seedKvPath`; this row indexes the stack-scoped binding so the
/// destroy path can revoke + propagate cleanly. The server-side cryptographic
/// guarantee (a JWT minted with this key cannot exceed `scopedSubject`) is
/// enforced by NATS via the scope template embedded in the account JWT.
model NatsSigningKey {
  id             String      @id @default(cuid())
  accountId      String
  account        NatsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  stackId        String
  stack          Stack       @relation("StackNatsSigningKey", fields: [stackId], references: [id], onDelete: Cascade)
  name           String      // template-author symbol, e.g. "worker-minter"
  scope          String      // relative scope as declared, e.g. "agent.worker"
  scopedSubject  String      // resolved absolute subject, e.g. "app.<stackId>.agent.worker.>"
  publicKey      String      // for cross-checking server-side validation
  seedKvPath     String      // shared/nats-signers/<stackId>-<name>
  maxTtlSeconds  Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([stackId, name])
  @@index([accountId])
  @@map("nats_signing_keys")
}

// StackService - Individual service within a stack
model StackService {
  id              String           @id @default(cuid())
  stackId         String
  stack           Stack            @relation(fields: [stackId], references: [id], onDelete: Cascade)
  serviceName     String
  serviceType     StackServiceType
  dockerImage     String
  dockerTag       String
  containerConfig Json             // StackContainerConfig shape
  configFiles     Json?            // Array of StackConfigFile
  initCommands    Json?            // Array of StackInitCommand
  dependsOn       Json             // Array of service name strings
  order           Int
  routing         Json?            // StackServiceRouting (required for StatelessWeb/AdoptedWeb, forbidden for Stateful)
  adoptedContainer Json?           // AdoptedContainerRef (required for AdoptedWeb)
  poolConfig      Json?            // PoolConfig (required for Pool services)
  poolManagementTokenHash   String? // bcrypt hash, rotated on every apply
  vaultAppRoleId              String?
  vaultAppRole                VaultAppRole? @relation("ServiceVaultAppRole", fields: [vaultAppRoleId], references: [id], onDelete: SetNull)
  lastAppliedVaultAppRoleId   String?
  natsCredentialId            String?
  natsCredential              NatsCredentialProfile? @relation("ServiceNatsCredential", fields: [natsCredentialId], references: [id], onDelete: SetNull)
  natsCredentialRef           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([stackId, serviceName])
  @@index([stackId])
  @@index([vaultAppRoleId])
  @@index([natsCredentialId])
  @@map("stack_services")
}

// PoolInstance - a live or historical instance of a Pool-type service.
// Status transitions: starting → running → stopped/error (or stopping → stopped).
// Partial unique index on (stackId, serviceName, instanceId) for active statuses
// is enforced via raw-SQL migration — Prisma doesn't support filtered indexes.
model PoolInstance {
  id                 String    @id @default(cuid())
  stackId            String
  stack              Stack     @relation(fields: [stackId], references: [id], onDelete: Cascade)
  serviceName        String
  instanceId         String
  containerId        String?
  status             String    // starting | running | stopping | stopped | error
  idleTimeoutMinutes Int
  lastActive         DateTime  @default(now())
  createdAt          DateTime  @default(now())
  stoppedAt          DateTime?
  errorMessage       String?

  @@index([stackId])
  @@index([stackId, serviceName])
  @@index([status])
  @@index([status, lastActive])
  @@map("pool_instances")
}

// StackDeployment - Immutable log of each apply/stop operation
model StackDeployment {
  id              String      @id @default(cuid())
  stackId         String
  stack           Stack       @relation(fields: [stackId], references: [id], onDelete: Cascade)
  action          String      // 'apply' | 'stop'
  success         Boolean
  version         Int?        // stack version at time of deploy (null for stop)
  status          StackStatus // resulting status after operation
  duration        Int?        // milliseconds
  serviceResults  Json?       // ServiceApplyResult[] for apply, null for stop
  resourceResults Json?       // ResourceApplyResult[] for resource operations
  error           String?     // error message if operation failed
  triggeredBy     String?     // user ID for audit trail
  createdAt       DateTime    @default(now())

  @@index([stackId])
  @@index([createdAt])
  @@map("stack_deployments")
}

// StackResource - Tracks state of stack-level resources (TLS certs, DNS records, tunnel ingress)
model StackResource {
  id            String   @id @default(cuid())
  stackId       String
  stack         Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  resourceType  String   // 'tls' | 'dns' | 'tunnel'
  resourceName  String   // name from the stack definition
  fqdn          String   // the domain this resource manages

  externalId    String?  // Cloudflare record ID, tunnel ingress ID, or TlsCertificate ID
  externalState Json?    // snapshot of what was applied

  status        String   @default("active") // 'active' | 'pending' | 'error'
  error         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([stackId, resourceType, resourceName])
  @@index([stackId])
  @@map("stack_resources")
}

// InfraResource - Shared infrastructure resources produced/consumed by stacks
model InfraResource {
  id            String       @id @default(cuid())
  type          String       // "docker-network" initially, extensible
  purpose       String       // "applications", "tunnel", "dataplane", "monitoring"
  scope         String       // "host" or "environment"
  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  stackId       String?
  stack         Stack?       @relation(fields: [stackId], references: [id], onDelete: SetNull)
  name          String       // actual Docker resource name (e.g., "staging-applications")
  dockerId      String?      // Docker resource ID when created
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([type, purpose, scope, environmentId])
  @@index([stackId])
  @@index([environmentId])
  @@map("infra_resources")
}

// StackTemplate - Reusable blueprint for stack definitions
model StackTemplate {
  id               String               @id @default(cuid())
  name             String
  displayName      String
  description      String?
  source           StackTemplateSource  // system | user
  scope            StackTemplateScope   // host | environment | any
  networkType      String?              // 'local' | 'internet' | null (null = compatible with both)
  category         String?
  environmentId    String?
  environment      Environment?         @relation(fields: [environmentId], references: [id])
  isArchived       Boolean              @default(false)

  // Pointer to the live published version (null until first publish)
  currentVersionId String?              @unique
  currentVersion   StackTemplateVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id])

  // Pointer to the in-progress draft (null when no draft exists)
  draftVersionId   String?              @unique
  draftVersion     StackTemplateVersion? @relation("DraftVersion", fields: [draftVersionId], references: [id])

  // Audit
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  createdById      String?

  // Relations
  versions         StackTemplateVersion[] @relation("AllVersions")
  stacks           Stack[]

  @@unique([name, source])
  @@index([source])
  @@index([scope])
  @@index([isArchived])
  @@index([environmentId])
  @@map("stack_templates")
}

// StackTemplateVersion - Immutable snapshot; draft has version=0, published versions are sequential
model StackTemplateVersion {
  id                     String                      @id @default(cuid())
  templateId             String
  template               StackTemplate               @relation("AllVersions", fields: [templateId], references: [id], onDelete: Cascade)
  version                Int
  status                 StackTemplateVersionStatus   // draft | published | archived
  notes                  String?
  parameters             Json                        // StackParameterDefinition[]
  defaultParameterValues Json                        // Record<string, StackParameterValue>
  networkTypeDefaults    Json                        // Record<EnvironmentNetworkType, Record<string, StackParameterValue>>
  resourceOutputs        Json?                       // Array of StackResourceOutput
  resourceInputs         Json?                       // Array of StackResourceInput
  networks               Json                        // StackNetwork[]
  volumes                Json                        // StackVolume[]
  publishedAt            DateTime?
  createdAt              DateTime                    @default(now())
  createdById            String?

  // Phase 2 — Vault dependency surface declared by the template author.
  // Stored as JSON blobs; validated at draft-save and publish time.
  inputs                 Json?                       // TemplateInputDeclaration[] — operator-supplied values
  vaultPolicies          Json?                       // TemplateVaultPolicy[]
  vaultAppRoles          Json?                       // TemplateVaultAppRole[]
  vaultKv                Json?                       // TemplateVaultKv[]
  natsAccounts           Json?                       // TemplateNatsAccount[]
  natsCredentials        Json?                       // TemplateNatsCredential[]
  natsStreams            Json?                       // TemplateNatsStream[]
  natsConsumers          Json?                       // TemplateNatsConsumer[]

  // Phase 1 — NATS app-author surface (roles/signers/imports/exports + prefix).
  // Persisted on the version row so apply-time orchestrator and cross-stack
  // consumers can resolve against the latest applied snapshot.
  natsSubjectPrefix      String?                     // e.g. "app.{{stack.id}}" or allowlisted "navi"
  natsRoles              Json?                       // TemplateNatsRole[]
  natsSigners            Json?                       // TemplateNatsSigner[]
  natsExports            Json?                       // string[] — *resolved* (prefixed) export subjects
  natsImports            Json?                       // TemplateNatsImport[]

  // Relations
  services               StackTemplateService[]
  configFiles            StackTemplateConfigFile[]

  // Back-relations for self-referential FKs on StackTemplate
  currentForTemplate     StackTemplate?              @relation("CurrentVersion")
  draftForTemplate       StackTemplate?              @relation("DraftVersion")

  @@unique([templateId, version])
  @@index([templateId])
  @@index([status])
  @@map("stack_template_versions")
}

// StackTemplateService - Service definition within a template version
model StackTemplateService {
  id              String                @id @default(cuid())
  versionId       String
  version         StackTemplateVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  serviceName     String
  serviceType     StackServiceType
  dockerImage     String
  dockerTag       String
  containerConfig Json                  // StackContainerConfig
  initCommands    Json?                 // StackInitCommand[]
  dependsOn       Json                  // string[]
  order           Int
  routing         Json?                 // StackServiceRouting | null
  adoptedContainer Json?                // AdoptedContainerRef (required for AdoptedWeb)
  poolConfig      Json?                 // PoolConfig (required for Pool services)
  vaultAppRoleId  String?               // Optional per-service Vault AppRole binding (resolved concrete ID)
  vaultAppRole    VaultAppRole?         @relation("TemplateServiceVaultAppRole", fields: [vaultAppRoleId], references: [id], onDelete: SetNull)
  // Phase 2 — symbolic AppRole name from vault.appRoles[]; resolved to vaultAppRoleId at apply time.
  vaultAppRoleRef String?
  natsCredentialId  String?
  natsCredential    NatsCredentialProfile? @relation("TemplateServiceNatsCredential", fields: [natsCredentialId], references: [id], onDelete: SetNull)
  natsCredentialRef String?
  // Phase 1 — symbolic refs into nats.roles[] and nats.signers[] declared on
  // the same StackTemplateVersion. Resolved at apply time: natsRole → bound
  // NatsCredentialProfile (auto-prefixed); natsSigner → auto-injected
  // NATS_SIGNER_SEED dynamicEnv. Mutually exclusive with natsCredentialRef.
  natsRole          String?
  natsSigner        String?

  @@unique([versionId, serviceName])
  @@index([versionId])
  @@index([vaultAppRoleId])
  @@index([natsCredentialId])
  @@map("stack_template_services")
}

// StackTemplateConfigFile - Config file stored against a template version
model StackTemplateConfigFile {
  id          String                @id @default(cuid())
  versionId   String
  version     StackTemplateVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  serviceName String
  fileName    String
  volumeName  String
  mountPath   String
  content     String                // Supports {{template}} variables
  permissions String?
  owner       String?

  @@unique([versionId, serviceName, volumeName, mountPath])
  @@index([versionId])
  @@map("stack_template_config_files")
}

// Egress Firewall Models

// EgressPolicy - one per environment-scoped stack; survives stack/environment deletion for audit
model EgressPolicy {
  id                      String       @id @default(cuid())

  stackId                 String?
  stack                   Stack?       @relation(fields: [stackId], references: [id], onDelete: SetNull)
  stackNameSnapshot       String

  environmentId           String?
  environment             Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  environmentNameSnapshot String

  mode                    String       @default("detect")  // 'detect' | 'enforce'
  defaultAction           String       @default("allow")   // 'allow' | 'block'
  version                 Int          @default(1)
  appliedVersion          Int?

  archivedAt              DateTime?
  archivedReason          String?      // 'stack-deleted' | 'environment-deleted'

  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  createdBy               String?
  updatedBy               String?

  rules                   EgressRule[]
  events                  EgressEvent[]

  @@index([stackId])
  @@index([environmentId])
  @@index([archivedAt])
  @@map("egress_policies")
}

// EgressRule - individual allow/block rule within an EgressPolicy
model EgressRule {
  id        String       @id @default(cuid())
  policyId  String
  policy    EgressPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  pattern   String       // 'api.openai.com' or '*.googleapis.com'
  action    String       // 'allow' | 'block'
  source    String       @default("user")   // 'user' | 'observed' | 'template'
  targets   Json         @default("[]")     // string[] of service names within the stack; [] means all

  hits      Int          @default(0)
  lastHitAt DateTime?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  createdBy String?
  updatedBy String?

  @@index([policyId])
  @@index([policyId, pattern])
  @@map("egress_rules")
}

// EgressEvent - gateway-emitted DNS query log entry for a policy
model EgressEvent {
  id                  String       @id @default(cuid())
  policyId            String
  policy              EgressPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  occurredAt          DateTime     @default(now())
  sourceContainerId   String?      // Docker container ID — plain string, no FK
  sourceStackId       String?      // plain string, no FK (stack may be deleted)
  sourceServiceName   String?
  destination         String       // queried domain name
  matchedPattern      String?      // pattern of the rule that matched, if any
  action              String       // 'allowed' | 'blocked' | 'observed'
  protocol            String       @default("dns")  // 'dns' | 'sni' | 'http' | 'connect' | 'tcp' | 'udp' | 'icmp'
  mergedHits          Int          @default(1)      // gateway-side dedup counter

  // v3 egress gateway fields — null for existing dns.query events
  target              String?      // CONNECT target or HTTP Host (e.g. "api.example.com:443")
  method              String?      // HTTP method (e.g. "GET")
  path                String?      // HTTP request path
  status              Int?         // HTTP response status code
  bytesUp             BigInt?      // bytes sent upstream (CONNECT events)
  bytesDown           BigInt?      // bytes received downstream
  destIp              String?      // destination IP (fw_drop events)
  destPort            Int?         // destination port (fw_drop events)
  reason              String?      // denial/drop reason (e.g. "rule-deny", "non-allowed-egress")

  @@index([policyId, occurredAt])
  @@index([policyId, action])
  @@map("egress_events")
}

// Cached DNS zone from Cloudflare
model DnsCacheZone {
  id               String   @id @default(cuid())
  cloudflareZoneId String   @unique
  name             String
  status           String
  paused           Boolean  @default(false)
  type             String
  nameServers      String   // JSON-encoded string[]
  createdOn        String?
  modifiedOn       String?
  cachedAt         DateTime @default(now())

  records DnsCacheRecord[]

  @@index([name])
  @@map("dns_cache_zones")
}

// Cached DNS record from Cloudflare
model DnsCacheRecord {
  id                 String       @id @default(cuid())
  cloudflareRecordId String       @unique
  zoneId             String
  zone               DnsCacheZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  type               String
  name               String
  content            String
  ttl                Int
  proxied            Boolean      @default(false)
  proxiable          Boolean      @default(true)
  locked             Boolean      @default(false)
  zoneName           String
  createdOn          String?
  modifiedOn         String?
  cachedAt           DateTime     @default(now())

  @@index([zoneId])
  @@index([name])
  @@index([type])
  @@map("dns_cache_records")
}
