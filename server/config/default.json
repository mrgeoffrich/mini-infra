{
  "server": {
    "nodeEnv": "development",
    "port": 5005,
    "publicUrl": "http://localhost:5005"
  },
  "database": {
    "url": "file:./dev.db"
  },
  "auth": {
    "google": {
      "clientId": null,
      "clientSecret": null
    },
    "session": {
      "secret": null
    },
    "apiKey": {
      "secret": "default-secret-change-in-production"
    }
  },
  "logging": {
    "level": "info"
  },
  "docker": {
    "containerCacheTtl": 3000,
    "containerPollInterval": 5000
  },
  "azure": {
    "apiTimeout": 15000
  },
  "connectivity": {
    "checkInterval": 300000
  },
  "telemetry": {
    "enabled": false,
    "serviceName": "mini-infra",
    "serviceVersion": "0.1.0",
    "samplingRatio": 1.0
  },
  "agent": {
    "model": "claude-sonnet-4-6",
    "thinking": "adaptive",
    "effort": "medium",
    "maxTurns": 20
  }
}