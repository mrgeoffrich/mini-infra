{
  "development": {
    "app": {
      "level": "info",
      "destination": "logs/app.log",
      "prettyPrint": true,
      "includeCaller": true,
      "rotation": {
        "enabled": false
      }
    },
    "http": {
      "level": "info",
      "destination": "logs/app-http.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": false
      }
    },
    "prisma": {
      "level": "debug",
      "destination": "logs/app-prisma.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": false
      }
    },
    "services": {
      "level": "debug",
      "destination": "logs/app-services.log",
      "prettyPrint": false,
      "includeCaller": true,
      "rotation": {
        "enabled": false
      }
    },
    "dockerexecutor": {
      "level": "debug",
      "destination": "logs/app-dockerexecutor.log",
      "prettyPrint": false,
      "includeCaller": true,
      "rotation": {
        "enabled": false
      }
    },
    "deployments": {
      "level": "debug",
      "destination": "logs/app-deployments.log",
      "prettyPrint": false,
      "includeCaller": true,
      "rotation": {
        "enabled": false
      }
    },
    "loadbalancer": {
      "level": "debug",
      "destination": "logs/app-loadbalancer.log",
      "prettyPrint": false,
      "includeCaller": true,
      "rotation": {
        "enabled": false
      }
    }
  },
  "production": {
    "app": {
      "level": "info",
      "destination": "logs/app.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": true,
        "maxFiles": "14d",
        "maxSize": "10m"
      }
    },
    "http": {
      "level": "info",
      "destination": "logs/app-http.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": true,
        "maxFiles": "14d",
        "maxSize": "10m"
      }
    },
    "prisma": {
      "level": "warn",
      "destination": "logs/app-prisma.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": true,
        "maxFiles": "14d",
        "maxSize": "10m"
      }
    },
    "services": {
      "level": "info",
      "destination": "logs/app-services.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": true,
        "maxFiles": "14d",
        "maxSize": "10m"
      }
    },
    "dockerexecutor": {
      "level": "info",
      "destination": "logs/app-dockerexecutor.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": true,
        "maxFiles": "14d",
        "maxSize": "10m"
      }
    },
    "deployments": {
      "level": "info",
      "destination": "logs/app-deployments.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": true,
        "maxFiles": "14d",
        "maxSize": "10m"
      }
    },
    "loadbalancer": {
      "level": "info",
      "destination": "logs/app-loadbalancer.log",
      "prettyPrint": false,
      "rotation": {
        "enabled": true,
        "maxFiles": "14d",
        "maxSize": "10m"
      }
    }
  },
  "test": {
    "app": {
      "level": "silent"
    },
    "http": {
      "level": "silent"
    },
    "prisma": {
      "level": "silent"
    },
    "services": {
      "level": "silent"
    },
    "dockerexecutor": {
      "level": "silent"
    },
    "deployments": {
      "level": "silent"
    },
    "loadbalancer": {
      "level": "silent"
    }
  },
  "openobserve": {
    "batchSize": 1000,
    "timeThreshold": 5000,
    "enabled": true
  },
  "redactionPaths": [
    "password",
    "token",
    "accessToken",
    "refreshToken",
    "authorization",
    "cookie",
    "sessionToken",
    "connectionString",
    "apiKey",
    "secret",
    "*.password",
    "*.token",
    "*.connectionString",
    "*.apiKey",
    "*.secret",
    "req.headers.authorization",
    "req.headers.cookie",
    "req.body.password",
    "res.headers[\"set-cookie\"]"
  ]
}