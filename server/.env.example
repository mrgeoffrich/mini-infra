# Database
DATABASE_URL="file:./dev.db"

# Authentication
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
SESSION_SECRET=your_session_secret_key
API_KEY_SECRET=your_api_key_secret_for_hashing
ENCRYPTION_SECRET=your_encryption_secret_for_credential_storage

# Admin Access Control (REQUIRED)
# Comma-separated list of email addresses allowed to log in via Google OAuth.
# All logins will be rejected if this is not set.
# Example: ALLOWED_ADMIN_EMAILS=admin@example.com,other@example.com
ALLOWED_ADMIN_EMAILS=

# Development API Key (Optional)
# Email for the automatically created development user (development mode only)
CLAUDE_DEV_USER_EMAIL=claude@development.local

# Server Configuration
NODE_ENV=development
PORT=5005

# Logging
LOG_LEVEL=debug

# Security & CORS
PUBLIC_URL=http://localhost:3000
# Set to true to disable HTTPS-enforcing headers (HSTS, CSP upgrade-insecure-requests) for HTTP-only environments
# NOTE: When PUBLIC_URL starts with 'http://', this is automatically set to true
# You only need to explicitly set ALLOW_INSECURE=true if using HTTP without a PUBLIC_URL
# WARNING: Only use in development or trusted environments behind a reverse proxy
ALLOW_INSECURE=false

# Docker Configuration
# Note: Docker host and API version are now configured via database settings only
CONTAINER_CACHE_TTL=3000
CONTAINER_POLL_INTERVAL=5000

# Azure Configuration
# Note: Azure connection strings are configured via database settings only
AZURE_API_TIMEOUT=15000
CONNECTIVITY_CHECK_INTERVAL=300000

# AI Assistant (Optional)
# Provide an Anthropic API key to enable the AI assistant chat feature
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# LangSmith Tracing (Optional)
# Enable tracing of AI agent interactions to LangSmith for observability
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=mini-infra