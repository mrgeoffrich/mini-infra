# Database
DATABASE_URL="file:./dev.db"

# Authentication
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
SESSION_SECRET=your_session_secret_key
API_KEY_SECRET=your_api_key_secret_for_hashing

# Development API Key (Optional)
# Email for the automatically created development user (development mode only)
CLAUDE_DEV_USER_EMAIL=claude@development.local

# Server Configuration
NODE_ENV=development
PORT=5000

# Logging
LOG_LEVEL=debug

# Security & CORS
PUBLIC_URL=http://localhost:3000

# Docker Configuration
# Note: Docker host and API version are now configured via database settings only
CONTAINER_CACHE_TTL=3000
CONTAINER_POLL_INTERVAL=5000

# Azure Configuration
# Note: Azure connection strings are configured via database settings only
AZURE_API_TIMEOUT=15000
CONNECTIVITY_CHECK_INTERVAL=300000

# OpenObserve Configuration (Optional)
# If all OpenObserve variables are provided, logs will be forwarded to OpenObserve
OPENOBSERVE_URL=https://your-openobserve-instance.com
OPENOBSERVE_ORGANIZATION_NAME=your_organization_name
OPENOBSERVE_USERNAME=your_username
OPENOBSERVE_PASSWORD=your_password
OPENOBSERVE_STREAM_NAME=mini-infra-logs

# OpenTelemetry Configuration (Optional)
# If OTEL_EXPORTER_OTLP_ENDPOINT is provided, distributed tracing will be enabled
OTEL_ENABLED=true
OTEL_SERVICE_NAME=mini-infra
OTEL_SERVICE_VERSION=0.1.0
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-openobserve-instance.com/api/your-org/traces
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic base64encodedcredentials
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development,service.namespace=mini-infra
OTEL_SAMPLING_RATIO=1.0
# Set to true to enable detailed console logging of all OpenTelemetry span data
OTEL_DEBUG=false