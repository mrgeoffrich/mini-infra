# Database
DATABASE_URL="file:./dev.db?foreign_keys=true&journal_mode=WAL"

# Application Secret (Optional)
# A single secret used for JWT signing, API key hashing, and credential encryption.
# If not set, one is auto-generated and stored in the database on first boot.
# APP_SECRET=your_secret_key

# Admin Access Control (Optional)
# Comma-separated list of email addresses allowed to log in.
# When set, only these emails can log in (applies to both local and Google OAuth).
# When not set, any user account in the database can log in.
# Example: ALLOWED_ADMIN_EMAILS=admin@example.com,other@example.com
ALLOWED_ADMIN_EMAILS=

# Development API Key (Optional)
# Email for the automatically created development user (development mode only)
CLAUDE_DEV_USER_EMAIL=claude@development.local

# Server Configuration (Optional)
# NODE_ENV=production          # defaults to "production"
# PORT=5005                    # defaults to 5005

# Logging
LOG_LEVEL=debug

# Security & CORS
PUBLIC_URL=http://localhost:3000
# Set to true to disable HTTPS-enforcing headers (HSTS, CSP upgrade-insecure-requests) for HTTP-only environments
# NOTE: When PUBLIC_URL starts with 'http://', this is automatically set to true
# You only need to explicitly set ALLOW_INSECURE=true if using HTTP without a PUBLIC_URL
# WARNING: Only use in development or trusted environments behind a reverse proxy
ALLOW_INSECURE=false
