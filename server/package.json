{
    "name": "mini-infra-server",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev": "npx prisma generate && tsx watch src/server.ts",
        "build": "npx prisma generate && tsc",
        "start": "node dist/server.js",
        "test": "npm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest run",
        "test:watch": "cross-env NODE_ENV=test vitest",
        "test:coverage": "cross-env NODE_ENV=test vitest run --coverage && npm run test:cleanup",
        "test:cleanup": "rimraf --glob \"prisma/test*.db\"",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write \"src/**/*.{ts,js}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js}\"",
        "justfix": "eslint --fix \"src/**/*.{ts,js}\" && eslint --fix",
        "show-dev-key": "tsx src/scripts/show-dev-api-key.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.34.0",
        "@paralleldrive/cuid2": "^2.2.2",
        "@types/adm-zip": "^0.5.7",
        "@types/better-sqlite3": "^7.6.13",
        "@types/config": "^3.3.5",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.13",
        "@types/crypto-js": "^4.2.2",
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.4.0",
        "@types/node-forge": "^1.3.14",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.16",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^8.41.0",
        "@typescript-eslint/parser": "^8.41.0",
        "cross-env": "^10.0.0",
        "eslint": "^9.34.0",
        "globals": "^16.3.0",
        "prettier": "^3.6.2",
        "prisma": "^6.16.2",
        "rimraf": "^6.1.3",
        "supertest": "^7.1.4",
        "tsx": "^4.21.0",
        "typescript": "^5.1.6",
        "typescript-eslint": "^8.41.0",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.2.62",
        "@azure/identity": "^4.13.0",
        "@azure/keyvault-certificates": "^4.10.0",
        "@azure/keyvault-secrets": "^4.10.0",
        "@azure/storage-blob": "^12.31.0",
        "@mini-infra/types": "file:../lib",
        "@octokit/rest": "^22.0.1",
        "@prisma/client": "^6.16.2",
        "@types/cloudflare": "^2.7.15",
        "@types/dockerode": "^3.3.43",
        "@types/js-yaml": "^4.0.9",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.15.5",
        "acme-client": "^5.4.0",
        "adm-zip": "^0.5.16",
        "argon2": "^0.44.0",
        "axios": "^1.13.5",
        "better-sqlite3": "^12.4.1",
        "cloudflare": "^4.5.0",
        "config": "^4.1.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cron-parser": "^5.3.1",
        "crypto-js": "^4.2.0",
        "dockerode": "^4.0.9",
        "dotenv": "^17.2.1",
        "express": "^5.2.1",
        "express-list-endpoints": "^7.1.1",
        "form-data": "^4.0.4",
