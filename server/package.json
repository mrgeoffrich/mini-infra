        "node-forge": "^1.3.3",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "pem": "^1.14.8",
        "pg": "^8.16.3",
        "pino": "^9.9.0",
        "pino-http": "^10.5.0",
        "pino-pretty": "^13.1.1",
        "pino-roll": "^3.1.0",
        "socket.io": "^4.8.3",
        "xstate": "^5.21.0",
        "zod": "^4.1.4"
    }
}
