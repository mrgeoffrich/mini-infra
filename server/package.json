{
    "name": "mini-infra-server",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev": "prisma generate && tsx watch src/server.ts",
        "build": "prisma generate && tsc",
        "start": "node dist/server.js",
        "test": "pnpm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest run --project unit --project integration",
        "test:watch": "cross-env NODE_ENV=test vitest --project unit --project integration",
        "test:coverage": "cross-env NODE_ENV=test vitest run --project unit --project integration --coverage && pnpm run test:cleanup",
        "test:external": "pnpm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest run --project external-integration",
        "test:nats": "pnpm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest run --project external-integration external",
        "test:all": "pnpm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest run",
        "test:cleanup": "rimraf --glob \"prisma/test*\"",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:tests": "eslint \"src/**/*.test.ts\" \"src/**/__tests__/**/*.ts\"",
        "lint:tests:fix": "eslint \"src/**/*.test.ts\" \"src/**/__tests__/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.{ts,js}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js}\"",
        "justfix": "eslint --fix \"src/**/*.{ts,js}\" && eslint --fix",
        "show-dev-key": "tsx src/scripts/show-dev-api-key.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@paralleldrive/cuid2": "^3.3.0",
        "@types/adm-zip": "^0.5.8",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cloudflare": "^3.0.0",
        "@types/config": "^4.4.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/dockerode": "^4.0.1",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.6.0",
        "@types/node-cron": "^3.0.11",
        "@types/node-forge": "^1.3.14",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^8.59.1",
        "@typescript-eslint/parser": "^8.59.1",
        "@vitest/coverage-v8": "^4.1.4",
        "cross-env": "^10.1.0",
        "eslint": "^10.2.0",
        "globals": "^17.5.0",
        "prettier": "^3.8.2",
        "rimraf": "^6.1.3",
        "supertest": "^7.2.2",
        "testcontainers": "^11.14.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.59.1",
        "vitest": "^4.1.4"
    },
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.2.126",
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@azure/identity": "^4.13.1",
        "@azure/keyvault-certificates": "^4.10.3",
        "@azure/keyvault-secrets": "^4.11.1",
        "@azure/storage-blob": "^12.31.0",
        "@mini-infra/acme": "workspace:*",
        "@mini-infra/types": "workspace:*",
        "@octokit/rest": "^22.0.1",
        "@prisma/adapter-better-sqlite3": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "adm-zip": "^0.5.17",
        "argon2": "^0.44.0",
        "better-sqlite3": "^12.8.0",
        "cloudflare": "^5.2.0",
        "config": "^4.4.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "cron-parser": "^5.5.0",
        "dockerode": "^5.0.0",
        "dotenv": "^17.4.1",
        "express": "^5.2.1",
        "express-list-endpoints": "^7.1.1",
        "form-data": "^4.0.5",
        "googleapis": "^144.0.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "nats": "^2.29.3",
        "nats-jwt": "^0.0.9",
        "nkeys.js": "^1.1.0",
        "node-cache": "^5.1.2",
        "node-cron": "^4.2.1",
        "node-forge": "^1.4.0",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "pino-roll": "^4.0.0",
        "prisma": "^7.7.0",
        "socket.io": "^4.8.3",
        "xstate": "^5.31.0",
        "zod": "^4.3.6"
    }
}
