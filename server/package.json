{
    "name": "mini-infra-server",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev": "npx prisma db push && tsx watch src/server.ts",
        "build": "npx prisma generate && tsc",
        "start": "node dist/server.js",
        "test": "npm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db npx prisma db push && cross-env NODE_ENV=test DATABASE_URL=file:./test.db jest",
        "test:watch": "cross-env NODE_ENV=test jest --watch",
        "test:coverage": "cross-env NODE_ENV=test jest --coverage && npm run test:cleanup",
        "test:cleanup": "rimraf --glob \"prisma/test*.db\"",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write \"src/**/*.{ts,js}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js}\"",
        "justfix": "eslint --fix \"src/**/*.{ts,js}\" && eslint --fix"
    },
    "devDependencies": {
        "@eslint/js": "^9.34.0",
        "@paralleldrive/cuid2": "^2.2.2",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.13",
        "@types/crypto-js": "^4.2.2",
        "@types/express": "^5.0.3",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.4.0",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.16",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^8.41.0",
        "@typescript-eslint/parser": "^8.41.0",
        "cross-env": "^10.0.0",
        "eslint": "^9.34.0",
        "globals": "^16.3.0",
        "jest": "^30.1.1",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "supertest": "^7.1.4",
        "ts-jest": "^29.4.1",
        "tsx": "^3.12.7",
        "typescript": "^5.1.6",
        "typescript-eslint": "^8.41.0"
    },
    "dependencies": {
        "@azure/storage-blob": "^12.28.0",
        "@mini-infra/types": "file:../lib",
        "@prisma/client": "^6.15.0",
        "@types/cloudflare": "^2.7.15",
        "@types/dockerode": "^3.3.43",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.15.5",
        "bull": "^4.16.5",
        "cloudflare": "^4.5.0",
        "config": "^4.1.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "crypto-js": "^4.2.0",
        "dockerode": "^4.0.7",
        "dotenv": "^17.2.1",
        "express": "^5.1.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "node-cache": "^5.1.2",
        "node-cron": "^4.2.1",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "pg": "^8.16.3",
        "pino": "^9.9.0",
        "pino-http": "^10.5.0",
        "pino-pretty": "^13.1.1",
        "pino-roll": "^3.1.0",
        "prisma": "^6.15.0",
        "zod": "^4.1.4"
    }
}