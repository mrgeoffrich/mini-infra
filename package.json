{
  "name": "mini-infra",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.32"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:lib\" \"pnpm dev:acme\" \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:lib": "pnpm --filter @mini-infra/types dev",
    "dev:acme": "pnpm --filter @mini-infra/acme dev",
    "dev:client": "pnpm --filter mini-infra-client dev",
    "dev:server": "pnpm --filter mini-infra-server dev",
    "build": "pnpm build:server && pnpm build:client",
    "build:lib": "pnpm --filter @mini-infra/types build",
    "build:acme": "pnpm --filter @mini-infra/acme build",
    "build:client": "pnpm --filter mini-infra-client build",
    "build:server": "pnpm build:lib && pnpm build:acme && pnpm --filter mini-infra-server build",
    "build:sidecar": "npm --prefix update-sidecar install && npm --prefix update-sidecar run build",
    "build:agent-sidecar": "npm --prefix agent-sidecar install && npm --prefix agent-sidecar run build",
    "build:pg-backup": "docker build -t mini-infra-pg-backup:dev ./pg-az-backup",
    "build:all": "pnpm build:lib && pnpm build:acme && concurrently \"pnpm build:client\" \"pnpm build:server\" \"pnpm build:sidecar\" \"pnpm build:agent-sidecar\"",
    "start": "pnpm --filter mini-infra-server start",
    "install:all": "pnpm install",
    "generate:ui-manifest": "node scripts/generate-ui-manifest.mjs",
    "format": "pnpm --filter mini-infra-server format",
    "format:check": "pnpm --filter mini-infra-server format:check"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "concurrently": "^9.2.1",
    "js-yaml": "^4.1.1",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "cross-env": "^10.1.0"
  }
}
