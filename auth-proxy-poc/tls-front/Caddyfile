{
	auto_https off
}

# Upstream hostnames are routed here via Docker network aliases on the
# client-net network. Caddy terminates TLS using the self-signed cert
# generated by cert-init, then rewrites the path to inject the auth-proxy's
# /<provider>/<tenant> prefix and forwards plain HTTP to auth-proxy.

api.anthropic.com {
	tls /certs/server.crt /certs/server.key
	rewrite * /anthropic/default{uri}
	reverse_proxy http://auth-proxy:8080
}

api.github.com {
	tls /certs/server.crt /certs/server.key
	rewrite * /github/default{uri}
	reverse_proxy http://auth-proxy:8080
}

www.googleapis.com, drive.googleapis.com, admin.googleapis.com, gmail.googleapis.com, people.googleapis.com {
	tls /certs/server.crt /certs/server.key
	rewrite * /gws/default{uri}
	reverse_proxy http://auth-proxy:8080
}
